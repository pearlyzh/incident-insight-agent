# === LLM Configuration ===
# GreenNode AI Platform API key (required)
AI_PLATFORM_API_KEY=your-api-key-here
# LLM endpoint (default: GreenNode MaaS)
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# Model to use (default: google/gemma-4-31b-it)
LLM_MODEL=google/gemma-4-31b-it

# === Jira Configuration (Data Center) ===
# Base URL of your Jira instance (e.g., https://jira.company.com)
JIRA_BASE_URL=https://your-jira-instance.com
# Option 1: Personal Access Token (recommended for DC)
JIRA_PAT=your-jira-pat-here
# Option 2: Basic Auth (username + password)
# JIRA_USERNAME=your-username
# JIRA_PASSWORD=your-password
# Set to "false" if using self-signed SSL certificates
JIRA_VERIFY_SSL=true

# === Confluence Configuration (Data Center) ===
# Base URL of your Confluence instance (e.g., https://confluence.company.com)
CONFLUENCE_BASE_URL=https://your-confluence-instance.com
# Uses JIRA_PAT / JIRA_USERNAME+PASSWORD by default if not set separately
# CONFLUENCE_PAT=your-confluence-pat-here
# CONFLUENCE_USERNAME=your-username
# CONFLUENCE_PASSWORD=your-password
CONFLUENCE_VERIFY_SSL=true
